# Configure your CDSE S3 credentials: https://eodata-s3keysmanager.dataspace.copernicus.eu/panel/s3-credentials

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

AWS_ENDPOINT_URL=https://eodata.dataspace.copernicus.eu/
AWS_S3_ENDPOINT=eodata.dataspace.copernicus.eu
AWS_VIRTUAL_HOSTING=False

# Enable Proj downloading and caching the transformation grids
# This allows using DEM on geoid heights like the Copernicus DEM and SRTM
PROJ_NETWORK=ON
